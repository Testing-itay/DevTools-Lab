{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"]
    },
    "custom-analytics": {
      "url": "https://analytics.internal.example.com/mcp/sse"
    },
    "datadog-monitoring": {
      "url": "https://mcp.datadog.example.com/v1/sse"
    },
    "jira-integration": {
      "url": "https://mcp-gateway.atlassian.example.com/jira/sse"
    },
    "linear-tracker": {
      "url": "https://mcp.linear.app/sse"
    },
    "code-search": {
      "command": "python",
      "args": ["mcp_servers/code_search_server.py", "--index-path", "./src"]
    },
    "doc-generator": {
      "command": "python",
      "args": ["mcp_servers/doc_generator_server.py", "--output", "./docs"]
    },
    "secret-scanner": {
      "command": "python",
      "args": ["mcp_servers/secret_scanner_server.py"]
    },
    "google-maps": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-maps"]
    },
    "code-sandbox": {
      "command": "npx",
      "args": ["-y", "vm2"]
    },
    "xml-processor": {
      "command": "npx",
      "args": ["-y", "xmlrpc"]
    },
    "template-engine": {
      "command": "npx",
      "args": ["-y", "handlebars"]
    },
    "arg-parser": {
      "command": "npx",
      "args": ["-y", "minimist"]
    },
    "object-utils": {
      "command": "npx",
      "args": ["-y", "lodash"]
    },
    "serializer": {
      "command": "npx",
      "args": ["-y", "node-serialize"]
    }
  }
}
